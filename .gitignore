# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# --- Virtual environment (rebuilt from uv.lock; never committed) ---
.venv/

# --- nox sessions ---
.nox/

# --- Secrets: NEVER commit these ---
# Real configuration with credentials and any local env files. The committed
# config/app.toml is the TEMPLATE with blank secrets; a populated local copy
# (if you make one) must not be tracked. Secrets live in machine env vars.
.env
.env.*
*.local.toml

# --- Runtime output ---
logs/
*.log

# --- OS / editor noise ---
.DS_Store
Thumbs.db
*.swp

# NOTE: uv.lock is intentionally NOT ignored. It is committed so deployments
# can `uv sync --frozen` against an exact, reproducible dependency set.
